# Copy this file to .env and adjust values for your local environment.
# Do NOT commit the real .env file — it is ignored by git.

# nginx — host port where the site is exposed
NGINX_PORT=80

# backend — internal port used by the Node.js service
BACKEND_PORT=3000

# postgres — credentials for the database service
POSTGRES_USER=greendevcorp
POSTGRES_PASSWORD=changeme
POSTGRES_DB=greendevcorp
